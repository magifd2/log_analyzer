# System Configuration for the Log Analyzer
# This file contains environment-specific settings like API endpoints and models.
# It is recommended to NOT commit this file to version control.

llm:
  # Base URL of the OpenAI-compatible API
  base_url: "http://localhost:1234/v1"
  # Model to use for analysis
  model: "openai/gpt-oss-20b"
  # Approximate maximum tokens for a single chunk before splitting.
  # This is not a hard limit, but a guideline for the chunking logic.
  max_tokens_per_chunk: 32768
  # Context window limit for the final summarization step. If the combined
  # summaries exceed this, the final summarization is skipped.
  max_summary_tokens: 16000
  # Character-per-token estimation factor. Tune this based on your log language.
  # Recommended values: 3.5 for English, 1.0-1.5 for Japanese.
  chars_per_token_estimate: 3.5

  # Optional parameters to pass to the LLM generation API.
  # These will be passed directly to the client.chat.completions.create() call.
  # Example:
  # generation_params:
  #   temperature: 0.7
  #   top_p: 1.0
  #   frequency_penalty: 0.0
  #   presence_penalty: 0.0
  generation_params: {}
